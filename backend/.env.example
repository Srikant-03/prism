# ─── Required ────────────────────────────────────────────────────────
# Gemini API key for AI features (Chat, Explain, Hypothesis Generator)
# Get yours from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# (Optional) Comma-separated list of keys for automatic rotation/failover
# GEMINI_API_KEYS=key1,key2,key3

# API key for authenticating all backend requests
DATA_INTEL_API_KEY=change-me-to-a-secure-secret

# ─── Server Configuration ───────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
# RATE_LIMIT=60/minute
# RATE_LIMIT_UPLOAD=10/minute

# ─── LLM Settings ───────────────────────────────────────────────────
# Models used for different levels of complexity
# LLM_MODEL_HEAVY=gemini-2.5-flash
# LLM_MODEL_WORKHORSE=gemini-2.5-flash
# LLM_MODEL_TRIAGE=gemini-2.5-flash-lite
LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=4096
