# ─── Required ────────────────────────────────────────────────────────
# Gemini API key for AI features (Chat, Explain, Hypothesis Generator)
# Get yours from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# API key for authenticating all backend requests
DATA_INTEL_API_KEY=change-me-to-a-secure-secret

# ─── Optional ────────────────────────────────────────────────────────
# Backend server settings (defaults shown)
HOST=0.0.0.0
PORT=8000
DEBUG=false

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# LLM settings
# LLM_MODEL_HEAVY=gemini-2.5-flash
# LLM_MODEL_WORKHORSE=gemini-2.5-flash
# LLM_TEMPERATURE=0.1
# LLM_MAX_TOKENS=4096
